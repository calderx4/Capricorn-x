# LLM API Key（必填）
# 当前使用 MiniMax M3（OpenAI 兼容接口）
# 获取地址：https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here

# 高德地图 MCP 服务器（可选）
# 获取地址：https://lbs.amap.com/
AMAP_MAPS_API_KEY=your_amap_api_key_here

# 飞书 Channel（可选）
# 获取地址：https://open.feishu.cn/app → 凭证与基础信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Gateway 认证（可选，不设则无需认证）
GATEWAY_API_KEY=
