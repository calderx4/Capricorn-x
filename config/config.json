{
  "workspace": {
    "root": "./workspace",
    "memory_dir": "memory",
    "session_dir": "sessions",
    "sandbox": true
  },

  "blocked_commands": [
    "rm -rf /",
    "mkfs",
    "dd if=",
    "format",
    "shutdown",
    "reboot"
  ],

  "llm": {
      "provider": "openai",
      "model": "MiniMax-M2.7",
      "api_key": "${MINIMAX_API_KEY}",
      "api_base": "https://api.minimaxi.com/v1",
      "temperature": 0.0,
      "max_tokens": 128000
    },

  "mcp_servers": {
    "amap": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@amap/amap-maps-mcp-server"],
      "env": {
        "AMAP_MAPS_API_KEY": "${AMAP_MAPS_API_KEY}"
      },
      "enabled": false,
      "enabled_tools": ["*"],
      "tool_timeout": 30
    },
    "minimax": {
      "type": "stdio",
      "command": "uvx",
      "args": ["minimax-coding-plan-mcp"],
      "env": {
        "MINIMAX_API_KEY": "${MINIMAX_API_KEY}",
        "MINIMAX_MCP_BASE_PATH": "./workspace",
        "MINIMAX_API_HOST": "https://api.minimaxi.com"
      },
      "enabled": true,
      "enabled_tools": ["*"],
      "tool_timeout": 60
    }
  },

  "memory": {
    "enabled": true,
    "message_threshold": 60,
    "messages_to_keep": 20,
    "token_threshold": 40000,
    "context_budget": 160000
  },

  "skills": {
    "skills_dir": "capabilities/skills/skills"
  },

  "agent": {
    "max_iterations": 50
  },

  "cron": {
    "enabled": true,
    "tick_interval": 60,
    "fresh_session": false
  },

  "gateway": {
    "host": "127.0.0.1",
    "port": 8080
  }
}
