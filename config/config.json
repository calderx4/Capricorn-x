{
  "workspace": {
    "root": "./workspace",
    "memory_dir": "memory",
    "session_dir": "sessions",
    "sandbox": true
  },

  "blocked_commands": [
    "rm -rf /",
    "mkfs",
    "dd if=",
    "format",
    "shutdown",
    "reboot"
  ],

  "allowed_commands": [],

  "llm": {
      "provider": "openai",
      "model": "MiniMax-M3",
      "api_key": "${MINIMAX_API_KEY}",
      "api_base": "https://api.minimaxi.com/v1",
      "temperature": 0.0,
      "max_tokens": 128000
    },

  "mcp_servers": {
    "amap": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@amap/amap-maps-mcp-server"],
      "env": {
        "AMAP_MAPS_API_KEY": "${AMAP_MAPS_API_KEY}"
      },
      "enabled": false,
      "enabled_tools": ["*"],
      "tool_timeout": 30
    },
    "minimax": {
      "type": "stdio",
      "command": "uvx",
      "args": ["minimax-coding-plan-mcp"],
      "env": {
        "MINIMAX_API_KEY": "${MINIMAX_API_KEY}",
        "MINIMAX_MCP_BASE_PATH": "./workspace",
        "MINIMAX_API_HOST": "https://api.minimaxi.com"
      },
      "enabled": true,
      "enabled_tools": ["*"],
      "tool_timeout": 60
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--headless"],
      "enabled": false,
      "enabled_tools": ["*"],
      "tool_timeout": 60
    }
  },

  "memory": {
    "enabled": true,
    "message_threshold": 60,
    "messages_to_keep": 20,
    "token_threshold": 80000,
    "max_memory_tokens": 3000,
    "max_history_entries": 100,
    "consolidation_ratio": 0.5
  },

  "skills": {
    "skills_dir": "capabilities/skills/skills"
  },

  "agent": {
    "max_iterations": 50
  },

  "cron": {
    "enabled": true,
    "tick_interval": 60,
    "fresh_session": false
  },

  "team": {
    "max_concurrent": 5,
    "max_attempts": 3,
    "max_questions": 3
  },

  "gateway": {
    "host": "127.0.0.1",
    "port": 8080
  },

  "channels": {
    "feishu": {
      "enabled": true,
      "app_id": "${FEISHU_APP_ID}",
      "app_secret": "${FEISHU_APP_SECRET}",
      "encrypt_key": "${FEISHU_ENCRYPT_KEY}",
      "verification_token": "${FEISHU_VERIFICATION_TOKEN}",
      "allow_from": ["*"]
    }
  }
}
